@page "/reader/available-books"
@using LibrarySystem.Client.Models
@using LibrarySystem.Client.Services
@inject BookService BookService

<PageTitle>Elérhető Könyvek</PageTitle>

<div class="container mt-4">
    <h2 class="mb-4">Kikölcsönözhető könyvek</h2>

    @if (availableBooks == null)
    {
        <div class="text-center"><p><em>Betöltés...</em></p></div>
    }
    else if (!availableBooks.Any())
    {
        <div class="alert alert-info">Jelenleg minden könyvünk ki van kölcsönözve. Látogasson vissza később!</div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var book in availableBooks)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">@book.Title</h5>
                            <h6 class="card-subtitle mb-2 text-muted">@book.Author</h6>
                            <p class="card-text">
                                <strong>Kiadó:</strong> @book.Publisher<br />
                                <strong>Év:</strong> @book.ReleaseYear
                            </p>
                        </div>
                        <div class="card-footer bg-transparent border-top-0">
                            <span class="badge bg-success">Elérhető</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<Book>? availableBooks;

    protected override async Task OnInitializedAsync()
    {
        availableBooks = await BookService.GetAvailableBooksAsync();
    }
}